# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — use test keys (sk_test_ / pk_test_) for local + staging; live keys for production only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create in Stripe dashboard, differ between test and live
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# App URL — http://localhost:3000 locally; your Vercel URL for staging/production
NEXT_PUBLIC_APP_URL=

# Resend — email notifications
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Supabase webhook secret — any random string; set the same value in Supabase dashboard webhook header
SUPABASE_WEBHOOK_SECRET=
